{
  "name": "eventos-backend",
  "version": "0.2.0",
  "description": "Backend de la app de eventos (graduaciones, universitarias y despedidas): API REST + PostgreSQL.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --env-file-if-exists=.env --watch server.js",
