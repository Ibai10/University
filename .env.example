# Copia este archivo a .env y ajusta los valores.

# Cambia esto por una cadena larga y aleatoria en producción.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Puerto donde arranca la API (Render lo define solo; en tu ordenador puedes
# dejarlo en 3001).
PORT=3001

# Cadena de conexión a PostgreSQL. Para desarrollo local con Postgres
# instalado en tu ordenador:
#   DATABASE_URL=postgres://postgres:tu_contraseña@localhost:5432/eventos
# Para Neon, Render Postgres, etc., cópiala tal cual te la den (empieza por
# postgres:// o postgresql://).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventos

# --- Email de la entrada (opcional para desarrollo) ---
# Si no rellenas RESEND_API_KEY, la app funciona igual pero no envía
# emails (avisa por consola y sigue). Consíguela gratis en resend.com.
RESEND_API_KEY=

# Remitente del email. Puedes dejarlo tal cual mientras pruebas — Resend
# permite enviar desde onboarding@resend.dev sin verificar un dominio
# propio. Cuando tengas dominio propio verificado en Resend, cámbialo por
# algo como "Fiestas Asturias <entradas@tudominio.com>".
EMAIL_FROM=Fiestas Asturias <onboarding@resend.dev>

# URL pública de este backend (para el enlace "Ver mi entrada" del email).
# En local: http://localhost:3001 (el enlace no será clicable desde el
# móvil, pero sirve para probar). En Render: tu URL real, ej.
# https://eventos-backend-i9gl.onrender.com
PUBLIC_APP_URL=http://localhost:3001
